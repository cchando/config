    # screen setup commands
		bindsym $alt+$mod+o mode "outputs"
		mode "outputs" {
				# laptop screen on
				bindsym d mode "dual screens"
				bindsym l mode "laptop screen"
				bindsym a mode "all screens"
        bindsym s exec "xrandr --output eDP-1 --off --output DP-1-3 --rotate left --output HDMI-1 --rotate right --right-of DP-1-3 ; sleep 4"; exec nitrogen --set-zoom-fill $bg; mode "default"
        # bindsym s exec "xrandr --output eDP-1 --off --output DP-1-3 --rotate left --output HDMI-1 --rotate right --right-of DP-1-3 ; sleep 4"; exec nitrogen --set-tiled $bg; mode "default"
				bindsym Escape mode "default"
				bindsym Return mode "default"
				bindsym space mode "default"
		}


    # setup commands for all screens at once
		# only reachable from "outputs" mode
		mode "all screens" {
        # dual monitors on, laptop screen off; TODO: sometimes works, sometimes doesn't. keybind works but xrandr command is flaky. results vary depending on order in which we tell it to turn the screens on.
        bindsym e exec xrandr --output HDMI-1 --auto --output DP-1-3 --auto --output eDP-1 --off; mode "default"
        bindsym u exec xrandr --output HDMI-1 --auto --output DP-1-3 --auto --output eDP-1 --off; mode "default"
        # laptop screen on, dual monitors off
        bindsym d exec xrandr --output DP-1-3 --off --output HDMI-1 --off --output eDP-1 --auto; mode "default"
        # set up dual screens correctly
        bindsym s exec "xrandr --output eDP-1 --off --output DP-1-3 --rotate left --output HDMI-1 --rotate right --right-of DP-1-3; sleep 4"; exec nitrogen --set-zoom-fill $bg; mode "default"
				bindsym Escape mode "default"
				bindsym Return mode "default"
				bindsym space mode "default"
		}


    # dual monitors setup commands
		# only reachable from "outputs" mode
        # dual monitors on, laptop screen off; TODO: sometimes works, sometimes doesn't. keybind works but xrandr command is flaky. results vary depending on order in which we tell it to turn the screens on.
		mode "dual screens" {
		    # right monitor rotate tall
		    bindsym bracketleft exec xrandr --output HDMI-1 --rotate right
		    # right monitor rotate wide
				bindsym bracketright exec xrandr --output HDMI-1 --rotate normal
		    # left monitor rotate tall
				bindsym Shift+bracketleft exec xrandr --output DP-1-3 --rotate left
		    # left monitor rotate wide
				bindsym Shift+bracketright exec xrandr --output DP-1-3 --rotate normal
				# both monitors on
        bindsym e exec xrandr --output HDMI-1 --auto --output DP-1-3 --auto; mode "default"
        bindsym u exec xrandr --output HDMI-1 --auto --output DP-1-3 --auto; mode "default"
				# turn on left monitor
        bindsym $left exec xrandr --output DP-1-3 --auto
				# turn on right monitor
        bindsym $right exec xrandr --output HDMI-1 --auto
				# both monitors off
        bindsym s exec "xrandr --output DP-1-3 --rotate left --output HDMI-1 --rotate right --right-of DP-1-3; sleep 4"; exec nitrogen --set-zoom-fill $bg; mode "default"
        bindsym d exec xrandr --output DP-1-3 --off --output HDMI-1 --off; mode "default"
				bindsym Escape mode "default"
				bindsym Return mode "default"
				bindsym space mode "default"
		}


    # laptop screen setup commands
		# only reachable from "outputs" mode
		mode "laptop screen" {
		    # laptop screen on
        bindsym e exec xrandr --output eDP-1 --auto; mode "default"
        bindsym u exec xrandr --output eDP-1 --auto; mode "default"
		    # laptop screen off
        bindsym d exec xrandr --output eDP-1 --off; mode "default"
				bindsym Escape mode "default"
				bindsym Return mode "default"
				bindsym space mode "default"
		}


    # i3 commands
		bindsym $alt+$mod+i mode "i3"
		mode "i3" {
        # reload the config file
				bindsym c reload
				# restart i3
				bindsym r restart
				# exit i3 (logs you out of your X session)
				bindsym $mod+Shift+e exit
				bindsym Escape mode "default"
				bindsym Return mode "default"
				bindsym space mode "default"
		}


